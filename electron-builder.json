{
  "appId": "com.tutormate.electron",
  "productName": "TutorMate",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": [
    "electron/**/*",
    "src/**/*",
    "assets/**/*",
    "data/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "build/installer-resources/bin",
      "to": "bin",
      "filter": [
        "llama-server.exe",
        "**/*.dll"
      ]
    },
    {
      "from": "build/installer-resources/models",
      "to": "models",
      "filter": [
        "**/*.gguf"
      ]
    }
  ],
  "asar": true,
  "win": {
    "target": [
      { "target": "nsis-web", "arch": ["x64"] }
    ],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "include": "build/installer.nsh",
    "preCompressedFileExtensions": [
      ".avi",
      ".mov",
      ".m4v",
      ".mp4",
      ".m4p",
      ".qt",
      ".mkv",
      ".webm",
      ".vmdk",
      ".gguf"
    ]
  },
  "nsisWeb": {
    "appPackageUrl": "https://example.invalid/tutormate"
  }
}
